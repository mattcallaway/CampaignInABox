_scaffold.ps1
tmp/
scratch/
*.tmp
*.bak

# Jupyter
.ipynb_checkpoints/

# Prompt 14 — War Room runtime data (never commit — may contain sensitive campaign data)
data/campaign_runtime/*
!data/campaign_runtime/**/.gitkeep
derived/war_room/private/*

# Large raw data (use LFS rules above for GIS)
# raw xlsx/xls vote files ARE committed (small; source of truth)
 
# Campaign Private Data Restrictions
/data/voters/
/data/campaign_runtime/
/data/private/
/data/intelligence/private/

# Historical Archive
# Allowed: models/, derived/archive/, reports/archive/
# Ignored: data/election_archive/raw_unnormalized/ (if any)

